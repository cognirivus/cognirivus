# Build-time public variables
# If you deploy from Cloudflare's Git-based Workers Builds, add these as Build variables.
PUBLIC_CONVEX_URL=https://your-project.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
PUBLIC_SITE_URL=https://your-app.example.com

# Server-side runtime variables
# Add these as Worker Variables & Secrets in Cloudflare or via Wrangler secrets.
CONVEX_DEPLOYMENT=your-convex-deployment
SITE_URL=https://your-app.example.com
OPENROUTER_API_KEY=your-openrouter-api-key
AI_GATEWAY_API_KEY=your-ai-gateway-api-key
DAYTONAIO_API_KEY=your-daytona-api-key
EXA_API_KEY=your-exa-api-key
SARVAM_API_KEY=your-sarvam-api-key
WORKOS_CLIENT_ID=your-workos-client-id
WORKOS_API_KEY=your-workos-api-key
WORKOS_REDIRECT_URI=https://your-app.example.com/callback
WORKOS_COOKIE_PASSWORD=replace-with-a-long-random-string
WORKOS_ADMIN_ORG_ID=your-workos-admin-org-id

# Convex R2 configuration
# These are used by the Convex backend, not by the Cloudflare Worker.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_BUCKET=your-r2-bucket
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_TOKEN=your-r2-api-token
